{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },

  "ConnectionStrings": {
    "EtlConnection": "Server=localhost;Username=postgres;Database=sqlviewer-etl;Port=54321;Password=postgres;"
  },
  
  "Services": {
    "Observability": {
      "ServiceName": "etl-worker",
      "WorkerMetricsPort": "5102",
      "JaegerEndpoint": "http://jaeger:4317"
    },

    "Kafka": {
      "Url": "localhost:9092"
    }
  },

  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Fatal" 
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "C:\\MyAppLogs\\sqlviewer\\etl-worker\\log.txt",
          "rollingInterval": "Day",
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] [{SourceContext}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  }
}
