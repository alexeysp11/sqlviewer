<UserControl x:Class="SqlViewer.UserControls.Menu"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SqlViewer.UserControls">
    <Grid>
        <Menu>
            <MenuItem Header="_File">
                <MenuItem Header="_New">
                    <MenuItem Header="_Database" Command="{Binding NewDatabaseCommand}" />
                    <MenuItem Header="_Table" Command="{Binding NewTableCommand}" />
                </MenuItem>
                <MenuItem Header="Connect to database" Command="{Binding ConnectCommand}" />
                <Separator/>
                <MenuItem Header="_Clear logs" Command="{Binding ClearLogsCommand}" />
                <Separator/>
                <MenuItem Header="_Exit" Command="{Binding ExitCommand}" />
            </MenuItem>

            <MenuItem Header="_Run">
                <MenuItem Header="_Query (F5)" Command="{Binding QuerySqlCommand}" />
                <MenuItem Header="_Stop" Command="{Binding CancelQueryCommand}" />
            </MenuItem>

            <MenuItem Header="_ETL">
                <MenuItem Header="_Table Structure" Command="{Binding DataContext.OpenEtlTableStructureCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                <MenuItem Header="_Data Transfer" Command="{Binding DataContext.OpenEtlDataTransferCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
            </MenuItem>

            <MenuItem Header="_Help">
                <MenuItem Header="Common SQL docs">
                    <MenuItem Header="SQLite" Command="{Binding HelpCommand}" CommandParameter="SqliteDocs" />
                    <MenuItem Header="PostgreSQL" Command="{Binding HelpCommand}" CommandParameter="PostgresDocs" />
                    <MenuItem Header="SQL Server" Command="{Binding HelpCommand}" CommandParameter="SqlServerDocs" />
                </MenuItem>
                <MenuItem Header="User guide">
                    <MenuItem Header="About" Command="{Binding HelpCommand}" CommandParameter="About" />
                </MenuItem>
            </MenuItem>
        </Menu>
    </Grid>
</UserControl>
