<Window x:Class="SqlViewer.Views.EtlDataTransferWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SqlViewer.Views"
        mc:Ignorable="d"
        WindowStartupLocation="CenterOwner"
        Title="sqlviewer: ETL" Height="450" Width="800">
    
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Headers -->
            <RowDefinition Height="*"/>    <!-- Active transfers -->
            <RowDefinition Height="1.5*"/>  <!-- History & logs -->
        </Grid.RowDefinitions>

        <!-- 1. Control panel -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
            <Button Content="Start New Transfer" Command="{Binding StartTransferCommand}" 
                    Padding="15,5" Background="#007ACC" Foreground="White" FontWeight="Bold"/>
            <Separator Margin="10,0" Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}"/>
            <TextBlock Text="Active Operations:" VerticalAlignment="Center" FontWeight="SemiBold"/>
        </StackPanel>

        <!-- 2. Active transfers (Dashboard) -->
        <GroupBox Grid.Row="1" Header="Live Transfer Dashboard" Margin="0,0,0,10">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding ActiveTransfers}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#DDD" BorderThickness="0,0,0,1" Padding="10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="3*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding TableName}" FontWeight="Bold"/>
                                        <TextBlock Text="{Binding CorrelationId}" FontSize="10" Foreground="Gray"/>
                                    </StackPanel>
                                    
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0">
                                        <ProgressBar Value="{Binding ProgressPercentage}" Height="15" Minimum="0" Maximum="100"/>
                                        <TextBlock Text="{Binding StatusMessage}" FontSize="11" HorizontalAlignment="Right"/>
                                    </StackPanel>

                                    <Button Grid.Column="2" Content="Cancel" Command="{Binding CancelCommand}" 
                                            VerticalAlignment="Center" Foreground="Red"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </GroupBox>

        <!-- 3. History & logs -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <GroupBox Header="Transfer History" Margin="0,0,5,0">
                <DataGrid ItemsSource="{Binding TransferHistory}" AutoGenerateColumns="False" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Timestamp" Binding="{Binding StartTime, StringFormat='HH:mm:ss'}"/>
                        <DataGridTextColumn Header="Source" Binding="{Binding SourceDb}"/>
                        <DataGridTextColumn Header="Target" Binding="{Binding TargetDb}"/>
                        <DataGridTextColumn Header="Rows" Binding="{Binding RowsProcessed}"/>
                        <DataGridTemplateColumn Header="Status">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Status}" 
                                               Foreground="{Binding StatusColor}"/> <!-- Success/Failed logic -->
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>

            <GroupBox Header="Saga Execution Logs" Grid.Column="1">
                <ListBox ItemsSource="{Binding ExecutionLogs}" Background="#1E1E1E" Foreground="#D4D4D4" FontFamily="Consolas" FontSize="11">
                    <!-- The stages are displayed here: Validating, Dispatched, Loading... -->
                </ListBox>
            </GroupBox>
        </Grid>
    </Grid>
</Window>
