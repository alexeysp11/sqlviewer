<Window x:Class="SqlViewer.Views.DataTransferWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SqlViewer.Views"
        xmlns:sys="clr-namespace:System.Windows;assembly=PresentationFramework"
        mc:Ignorable="d"
        WindowStartupLocation="CenterOwner"
        Title="sqlviewer: ETL" Height="450" Width="800">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <Grid Margin="5">
        <TabControl>
            <!-- Tab 1: configurations -->
            <TabItem Header="Configuration">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="15">
                        <TextBlock Text="Database Connection Settings" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Source Settings -->
                            <GroupBox Header="Source" Margin="5">
                                <StackPanel Margin="5">
                                    <TextBlock Text="Database Type:" FontSize="10" Foreground="Gray"/>
                                    <ComboBox ItemsSource="{Binding DatabaseTypes}" SelectedItem="{Binding SourceType}" Margin="0,5"/>

                                    <TextBlock Text="Connection String:" FontSize="10" Foreground="Gray" Margin="0,5,0,0"/>
                                    <TextBox Text="{Binding SourceConnectionString, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" MinHeight="50"/>

                                    <Button Content="Load tables" Command="{Binding LoadSourceTablesCommand}" Margin="0,5"/>
                                    <TextBlock Text="Table Name:" FontSize="10" Foreground="Gray" Margin="0,10,0,0"/>
                                    <ComboBox ItemsSource="{Binding SourceTables}" SelectedItem="{Binding SelectedTableName}" Margin="0,5"/>
                                </StackPanel>
                            </GroupBox>

                            <!-- Target Settings -->
                            <GroupBox Header="Target" Grid.Column="1" Margin="5">
                                <StackPanel Margin="5">
                                    <TextBlock Text="Database Type:" FontSize="10" Foreground="Gray"/>
                                    <ComboBox ItemsSource="{Binding DatabaseTypes}" SelectedItem="{Binding TargetType}" Margin="0,5"/>

                                    <TextBlock Text="Connection String:" FontSize="10" Foreground="Gray" Margin="0,5,0,0"/>
                                    <TextBox Text="{Binding TargetConnectionString, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" MinHeight="50"/>
                                </StackPanel>
                            </GroupBox>
                        </Grid>

                        <Button Content="Start Transfer" 
                                Command="{Binding StartTransferCommand}" 
                                Margin="5,20,5,5" Height="40"
                                Background="#007ACC" Foreground="White" FontWeight="Bold"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Tab 2: Current status and logs -->
            <TabItem Header="Status">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <!-- Dashboard -->
                        <RowDefinition Height="150"/>
                        <!-- Logs -->
                    </Grid.RowDefinitions>

                    <GroupBox Header="Live Transfer Dashboard" Margin="0,0,0,10">
                        <Grid>
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl x:Name="ActiveItemsControl" ItemsSource="{Binding ActiveTransfers}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="#EEE" BorderThickness="0,0,0,1" Padding="8">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="180"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="80"/>
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding TableName}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Text="{Binding StatusMessage}" FontSize="9" Foreground="Gray"/>
                                                    </StackPanel>

                                                    <ProgressBar Grid.Column="1" Value="{Binding ProgressPercentage}" Height="12" Margin="10,0" VerticalAlignment="Center"/>
                                                    <Button Grid.Column="2" Content="Stop" Command="{Binding CancelCommand}" FontSize="11" Background="#FFF0F0" Foreground="DarkRed"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <!-- A caption that disappears if there are elements -->
                            <TextBlock x:Name="EmptyStateText" 
                                       Text="No active transfers" 
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center" 
                                       Foreground="LightGray">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <!-- If there are no elements in the collection, show the text -->
                                            <DataTrigger Binding="{Binding ActiveTransfers.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </GroupBox>

                    <GroupBox Header="Execution Logs" Grid.Row="1">
                        <ListBox ItemsSource="{Binding ExecutionLogs}" Background="#1E1E1E" Foreground="#D4D4D4" FontFamily="Consolas" FontSize="11"/>
                    </GroupBox>
                </Grid>
            </TabItem>

            <!-- Tab 3: History -->
            <TabItem Header="History">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/> <!-- History loading control button -->
                    </Grid.RowDefinitions>

                    <GroupBox Header="Transfer History" Grid.Row="0">
                        <DataGrid ItemsSource="{Binding TransferHistory}" 
                                AutoGenerateColumns="False" 
                                IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Time" Binding="{Binding Time, StringFormat='yyyy-MM-dd HH:mm:ss'}" Width="150"/>
                                <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="*"/>
                                <DataGridTextColumn Header="Target" Binding="{Binding Target}" Width="*"/>
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </GroupBox>

                    <!-- History loading control button -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,5,0,0">
                        <ProgressBar IsIndeterminate="True" 
                                Width="100" Height="10" 
                                Margin="0,0,10,0"
                                Visibility="{Binding IsLoadingHistory, Converter={StaticResource BoolToVis}}"/>

                        <Button Content="Refresh"
                                Command="{Binding LoadMoreHistoryCommand}"
                                Padding="15,5"
                                Margin="0,0,10,0"/>
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
