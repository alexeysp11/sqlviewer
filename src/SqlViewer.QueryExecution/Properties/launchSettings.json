{
  "profiles": {
    "http": {
      "commandName": "Project",
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "Kestrel__Endpoints__Http__Url": "http://localhost:5249",
        "Kestrel__Endpoints__Http__Protocols": "Http1",
        "Kestrel__Endpoints__Grpc__Url": "http://localhost:5250",
        "Kestrel__Endpoints__Grpc__Protocols": "Http2"
      },
      "dotnetRunMessages": true,
      "applicationUrl": "http://localhost:5249,http://localhost:5250"
    },
    "Container (Dockerfile)": {
      "commandName": "Docker",
      "launchUrl": "{Scheme}://{ServiceHost}:{ServicePort}/metrics",
      "environmentVariables": {
        "Kestrel__Endpoints__Http__Url": "http://+:8080",
        "Kestrel__Endpoints__Http__Protocols": "Http1",
        "Kestrel__Endpoints__Grpc__Url": "http://+:8082",
        "Kestrel__Endpoints__Grpc__Protocols": "Http2"
      },
      "publishAllPorts": true,
      "useSSL": true
    }
  },
  "$schema": "http://json.schemastore.org/launchsettings.json"
}