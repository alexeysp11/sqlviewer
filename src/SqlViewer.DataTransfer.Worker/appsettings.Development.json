{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },

  "ConnectionStrings": {
    "DataTransferConnection": "Server=localhost;Username=postgres;Database=sqlviewer-data-transfer;Port=54321;Password=postgres;",
    "RedisConnection": "localhost:6379,abortConnect=false"
  },

  "Services": {
    "Observability": {
      "ServiceName": "data-transfer-worker",
      "WorkerMetricsPort": "5103",
      "JaegerEndpoint": "http://jaeger:4317"
    },

    "Kafka": {
      "Url": "localhost:9092",
      "Topics": {
        "DataTransferCommand": "data-transfer-commands",
        "DataTransferStatusUpdates": "data-transfer-status-updates"
      },
      "Groups": {
        "DataTransferWorkerGroup": "data-transfer-worker-groups"
      }
    }
  },

  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.EntityFrameworkCore": "Fatal"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "C:\\MyAppLogs\\sqlviewer\\data-transfer-worker\\log.txt",
          "rollingInterval": "Day",
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] [{SourceContext}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  }
}
